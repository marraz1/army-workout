// Prisma schema — Neon Postgres
// Apply with: npx prisma db push   (after DATABASE_URL is set in .env)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  password           String
  createdAt          DateTime           @default(now())
  profile            Profile?
  workoutLogs        WorkoutLog[]
  workoutPlans       WorkoutPlan[]
  workoutSessions    WorkoutSession[]
  personalBests      PersonalBest[]
  customExercises    CustomExercise[]
  calisthenicsPlans  CalisthenicsPlan[]
  calisthenicsLogs   CalisthenicsLog[]
}

// One-to-one onboarding profile for each user.
model Profile {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String   @default("Recruit")
  age          Int      @default(30)
  gender       String   @default("M") // 'M' | 'F'
  fitnessLevel String   @default("Intermediate") // Beginner | Intermediate | Advanced
  language     String   @default("EN") // 'EN' | 'LT'
  wakeTime     String   @default("06:00")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// One workout log per user per day.
model WorkoutLog {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     String // ISO date YYYY-MM-DD
  status   String // 'completed' | 'skipped' | 'cheat'
  reason   String?
  loggedAt DateTime @default(now())

  @@unique([userId, date])
}

// ─── v1.1 ──────────────────────────────────────────────────────────────────

// A user's override of an exercise's plan (sets/reps/goal/rest). Effective plan
// = age-group default overlaid with these rows.
model WorkoutPlan {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId String // slug
  setsCount  Int
  repsTarget Int
  goalTarget String?
  restSec    Int
  runGoalSec Int?
  removed    Boolean  @default(false) // supports "Remove Exercise"
  isCustom   Boolean  @default(true)
  scope      String   @default("all") // 'all' | 'once'
  onceDate   String?
  muscleData String?  // JSON: { primary: string[], secondary: string[] }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, exerciseId, scope, onceDate])
  @@index([userId])
}

// A saved training session with rich set/run data.
model WorkoutSession {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             String
  dayType          String
  status           String // completed | partial | skipped | cheat
  energyRating     Int? // 1–5
  notes            String? // <=300 chars
  totalDurationMin Int?
  createdAt        DateTime       @default(now())
  sets             SessionSet[]
  runLog           RunLog?
  personalBests    PersonalBest[]

  @@index([userId, date])
}

model SessionSet {
  id          String         @id @default(cuid())
  sessionId   String
  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId  String
  setNumber   Int
  plannedReps Int
  actualReps  Int
  completed   Boolean        @default(false)

  @@index([sessionId])
}

model RunLog {
  id            String         @id @default(cuid())
  sessionId     String         @unique
  session       WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  distanceKm    Float?
  goalTimeSec   Int?
  actualTimeSec Int?
}

model PersonalBest {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId String
  metric     String // maxReps | fastestRunSec | longestHoldSec
  value      Float
  sessionId  String?
  session    WorkoutSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  date       String
  updatedAt  DateTime        @updatedAt

  @@unique([userId, exerciseId, metric])
  @@index([userId])
}

// ─── v2.0 Calisthenics ────────────────────────────────────────────────────────

model CalisthenicsExercise {
  id              Int                @id @default(autoincrement())
  name            String
  level           String             // 'Beginner' | 'Intermediate' | 'Advanced'
  muscles         String[]
  description     String?
  defaultSets     Int                @default(3)
  defaultReps     Int                @default(10)
  defaultRestSec  Int                @default(60)
  isTimed         Boolean            @default(false)
  illustrationKey String?
  progressions    String[]
  plans           CalisthenicsPlan[]

  @@map("calisthenics_exercises")
}

model CustomExercise {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  muscles              String[]
  level                String             @default("Beginner")
  defaultSets          Int                @default(3)
  defaultRepsOrSecs    Int                @default(10)
  isTimed              Boolean            @default(false)
  restSec              Int                @default(60)
  description          String?
  notes                String?
  illustrationTemplate String?            // 'push' | 'pull' | 'squat' | 'hold'
  createdAt            DateTime           @default(now())
  plans                CalisthenicsPlan[]

  @@index([userId])
  @@map("custom_exercises")
}

model CalisthenicsPlan {
  id                String                @id @default(cuid())
  userId            String
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  source            String                // 'library' | 'custom'
  libraryExerciseId Int?
  libraryExercise   CalisthenicsExercise? @relation(fields: [libraryExerciseId], references: [id], onDelete: SetNull)
  customExerciseId  String?
  customExercise    CustomExercise?       @relation(fields: [customExerciseId], references: [id], onDelete: SetNull)
  dayOfWeek         Int                   // 0=Sun … 6=Sat
  timeOfDay         String                @default("07:00")
  sets              Int
  repsOrSecs        Int
  restSec           Int                   @default(60)
  goalTarget        String?
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  logs              CalisthenicsLog[]

  @@index([userId])
  @@map("calisthenics_plans")
}

model CalisthenicsLog {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String?
  plan        CalisthenicsPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  source      String            // 'library' | 'custom'
  exerciseId  String            // library Int as String, or custom cuid
  sessionDate String            // YYYY-MM-DD
  setNumber   Int
  plannedReps Int
  actualReps  Int
  completed   Boolean           @default(false)
  notes       String?
  createdAt   DateTime          @default(now())

  @@index([userId, sessionDate])
  @@map("calisthenics_logs")
}
