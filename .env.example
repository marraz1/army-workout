# Copy to .env and fill in real values.

# Neon Postgres — dashboard → Connect → "Prisma" / pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth secret — generate: npx auth secret  (or: openssl rand -base64 32)
NEXTAUTH_SECRET=""
# Base URL of the app (http://localhost:3000 locally; your Vercel URL in prod)
NEXTAUTH_URL="http://localhost:3000"
